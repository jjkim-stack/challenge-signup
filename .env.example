# 이 파일을 복사해서 .env 로 저장한 뒤, 값을 채워 넣으세요.
# .env 는 절대 외부에 공유하지 마세요 (git에도 올라가지 않습니다).

# Supabase 연결 문자열 (Supabase → Project Settings → Database → Connection string → URI)
# [YOUR-PASSWORD] 부분을 실제 DB 비밀번호로 바꿔 넣으세요.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxx.supabase.co:5432/postgres

# 관리자 페이지 비밀번호 (원하는 값으로 변경)
ADMIN_PASSWORD=여기에_원하는_비밀번호
